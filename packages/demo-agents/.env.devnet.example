# .env.devnet — Agent keypairs for devnet demo
# Copy to .env.devnet and populate with real keypairs (byte arrays as JSON)
# Generate with: node -e "const {Keypair}=require('@solana/web3.js'); const k=Keypair.generate(); console.log(JSON.stringify(Array.from(k.secretKey)))"

# Agent A — Orchestrator: queries registry, locks escrow, pays
AGENT_A_KEYPAIR=[...]
AGENT_A_PUBKEY=<base58-public-key>

# Agent B — Specialist (Primary): registered on-chain, delivers work, earns
AGENT_B_KEYPAIR=[...]
AGENT_B_PUBKEY=<base58-public-key>

# Agent C — Judge (Attestation): scores Agent B's work
AGENT_C_KEYPAIR=[...]
AGENT_C_PUBKEY=<base58-public-key>

# Optional private-transfer contract knobs (MagicBlock ONE-style semantics)
# Applies when DEMO_SETTLEMENT_MODE != public
# DEMO_PRIVATE_MIN_DELAY_MS=1000
# DEMO_PRIVATE_MAX_DELAY_MS=5000
# DEMO_PRIVATE_SPLIT=3

# Optional mint-readiness preflight (Phase B guardrail)
# If DEMO_PRIVATE_MINT is set, demo checks /v1/spl/is-mint-initialized before private route
# DEMO_PRIVATE_MINT=<spl-mint-pubkey>
# DEMO_PAYMENTS_API_BASE_URL=https://payments.magicblock.app
# DEMO_PAYMENTS_CLUSTER=devnet
# DEMO_PAYMENTS_VALIDATOR_PUBKEY=FnE6VJT5QNZdedZPnCoLsARgBwoE6DeJNjBs2H1gySXA
# DEMO_REQUIRE_MINT_READY=false
# Then run: npm run mint:init-helper
