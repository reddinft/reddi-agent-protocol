# Existing plugin signer (used by x402_pay / x402_earn)
# JSON byte array, e.g. [12,34,...]
SOLANA_KEYPAIR=

# Vanish Core private swap (feature-flagged scaffold)
X402_ENABLE_VANISH_PRIVATE_SWAP=false
VANISH_BASE_URL=https://core-api.vanish.trade
VANISH_API_KEY=

# Optional: dedicated signer for Vanish details format.
# If omitted, plugin falls back to SOLANA_KEYPAIR.
VANISH_SIGNER_SECRET_KEY=
