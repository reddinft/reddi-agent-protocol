# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Rust / Anchor
target/
.anchor/
test-ledger/
**/*.so.map

# Solana keypairs (never commit secrets)
*-keypair.json
!.config/solana/
.config/solana/id.json

# Local protocol runtime state and generated artifacts
.surfpool/
artifacts/
test-results/

# Onboarding/demo runtime data (generated locally; may contain endpoint tokens, wallets, prompts, receipts)
data/onboarding/attestations.json
data/onboarding/dogfood-escrows.json
data/onboarding/local-wallet.json
data/onboarding/planner-feedback.json
data/onboarding/planner-runs.json
data/onboarding/runtime-config.json
data/onboarding/specialist-profile.json
data/onboarding/token-gated-proxy.mjs

# Package-local dependency/build outputs
**/node_modules/
packages/openrouter-specialists/dist/
